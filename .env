# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DB_NAME=jbesion_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
